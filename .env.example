# LLM API Keys — store in Google Secret Manager in production, never commit this file
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# Firebase
FIREBASE_PROJECT_ID=nyaayasetu-prod
# On Cloud Run, use Application Default Credentials (no key file needed)
